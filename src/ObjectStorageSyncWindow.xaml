<Window x:Class="file_sync.ObjectStorageSyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="同步到对象存储" Height="850" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        Icon="icon.ico">

    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 返回主页 -->
        <Button x:Name="BackButton" Grid.Row="0" Content="← 返回主页"
                Background="Transparent" Foreground="#0078D4" BorderThickness="0"
                Padding="0" Margin="0,0,0,15" HorizontalAlignment="Left"
                Cursor="Hand" FontSize="13" Click="BackButton_Click"/>

        <!-- 第一行：存储配置 -->
        <GroupBox Grid.Row="1" Header="存储配置" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 存储类型 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="存储类型:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <ComboBox x:Name="StorageTypeComboBox" Grid.Row="0" Grid.Column="1" SelectedIndex="{Binding StorageType}"
                          Margin="0,0,0,10" HorizontalAlignment="Left" Width="180"
                          SelectionChanged="StorageTypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="AWS S3"/>
                    <ComboBoxItem Content="阿里云 OSS"/>
                    <ComboBoxItem Content="腾讯云 COS"/>
                    <ComboBoxItem Content="MinIO"/>
                </ComboBox>
                <TextBlock x:Name="EndpointHint" Grid.Row="0" Grid.Column="2" Text="s3.amazonaws.com"
                           VerticalAlignment="Center" Margin="15,0,0,10" Foreground="#999" FontSize="12"/>

                <!-- Endpoint -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Endpoint:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <!-- AccessKey -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="AccessKey:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <PasswordBox x:Name="AccessKeyBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10"/>

                <!-- SecretKey -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="SecretKey:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <PasswordBox x:Name="SecretKeyBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10"/>

                <!-- Bucket -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Bucket:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Bucket, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </GroupBox>

        <!-- 第二行：上传到对象存储 -->
        <GroupBox Grid.Row="2" Header="上传到对象存储" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 本地目录 + 路径前缀 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="本地目录:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding LocalDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Column="2" Text="前缀:" VerticalAlignment="Center" Margin="10,0,10,0"/>
                    <TextBox Grid.Column="3" Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                    <Button x:Name="BrowseButton" Grid.Column="4" Content="浏览..." Width="80"/>
                </Grid>

                <!-- 同步模式 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="同步模式:" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="Bold"/>
                    <RadioButton x:Name="Mode0Radio" Content="仅上传新增" GroupName="SyncMode" Tag="0" Margin="0,0,15,0"/>
                    <RadioButton x:Name="Mode1Radio" Content="上传+更新" GroupName="SyncMode" Tag="1" IsChecked="True" Margin="0,0,15,0"/>
                    <RadioButton x:Name="Mode2Radio" Content="上传后删除本地" GroupName="SyncMode" Tag="2"/>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ScanButton" Content="{Binding ScanButtonContent, Mode=OneWay}"
                            Width="100" Margin="0,0,10,0" IsEnabled="{Binding CanScan, Mode=OneWay}"/>
                    <Button x:Name="SyncButton" Content="{Binding SyncButtonContent, Mode=OneWay}"
                            Width="100" Margin="0,0,10,0" IsEnabled="{Binding CanSync, Mode=OneWay}"/>
                    <Button x:Name="CancelButton" Content="取消" Width="80" IsCancel="True"
                            IsEnabled="{Binding CanCancel, Mode=OneWay}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 第三行：从对象存储下载 -->
        <GroupBox Grid.Row="3" Header="从对象存储下载" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 下载路径前缀 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="下载路径:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding DownloadPrefix, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button x:Name="BrowseDownloadDirButton" Grid.Column="2" Content="浏览..." Width="80" Margin="10,0,0,0"/>
                </Grid>

                <!-- 通配符 -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="通配符:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding WildcardPattern, UpdateSourceTrigger=PropertyChanged}"
                             Tag="(如 *.jpg, *.png, folder/*.zip)"/>
                </Grid>

                <!-- 列出文件 + 下载按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ListRemoteButton" Content="列出文件" Width="100" Margin="0,0,10,0"/>
                    <Button x:Name="DownloadButton" Content="下载" Width="100" IsEnabled="{Binding CanDownload, Mode=OneWay}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 第四行：进度条 -->
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                         Height="20" Minimum="0" Maximum="100"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 第五行：日志区域 -->
        <GroupBox Grid.Row="5" Header="操作日志" Padding="10">
            <ListBox x:Name="LogListBox" ItemsSource="{Binding Logs}" BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
    </Grid>
    </ScrollViewer>
</Window>
