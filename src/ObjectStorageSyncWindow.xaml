<Window x:Class="file_sync.ObjectStorageSyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="同步到对象存储" Height="900" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        Icon="icon.ico">

    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 返回主页 -->
        <Button x:Name="BackButton" Grid.Row="0" Content="← 返回主页"
                Background="Transparent" Foreground="#0078D4" BorderThickness="0"
                Padding="0" Margin="0,0,0,10" HorizontalAlignment="Left"
                Cursor="Hand" FontSize="13" Click="BackButton_Click"/>

        <!-- 配置区域 -->
        <GroupBox Grid.Row="1" Header="目录与存储配置" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 本地目录 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="本地目录:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding LocalDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button x:Name="BrowseButton" Grid.Column="2" Content="浏览..."
                            Width="80" Margin="10,0,0,0"/>
                </Grid>

                <!-- 存储类型 -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="存储类型:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="StorageTypeComboBox" Grid.Column="1" SelectedIndex="{Binding StorageType}"
                              SelectionChanged="StorageTypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="AWS S3"/>
                        <ComboBoxItem Content="阿里云 OSS"/>
                        <ComboBoxItem Content="腾讯云 COS"/>
                        <ComboBoxItem Content="MinIO"/>
                    </ComboBox>
                    <TextBlock x:Name="EndpointHint" Grid.Column="2" Text="s3.amazonaws.com"
                               VerticalAlignment="Center" Margin="15,0,0,0" Foreground="#999" FontSize="12"/>
                </Grid>

                <!-- Endpoint -->
                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Endpoint:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- AccessKey -->
                <Grid Grid.Row="3" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="AccessKey:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <PasswordBox x:Name="AccessKeyBox" Grid.Column="1"/>
                </Grid>

                <!-- SecretKey -->
                <Grid Grid.Row="4" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SecretKey:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <PasswordBox x:Name="SecretKeyBox" Grid.Column="1"/>
                </Grid>

                <!-- Bucket -->
                <Grid Grid.Row="5" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Bucket:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding Bucket, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- 路径前缀 -->
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="路径前缀:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}"
                             Tag="(可选)"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- 从对象存储下载 -->
        <GroupBox Grid.Row="2" Header="从对象存储下载" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 通配符下载 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="下载路径:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding DownloadPrefix, UpdateSourceTrigger=PropertyChanged}"
                             Tag="(可选，填写路径前缀如 folder/）"/>
                    <Button x:Name="BrowseDownloadDirButton" Grid.Column="2" Content="浏览..."
                            Width="80" Margin="10,0,0,0"/>
                </Grid>

                <!-- 通配符 + 下载按钮 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="通配符:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding WildcardPattern, UpdateSourceTrigger=PropertyChanged}"
                             Tag="(如 *.jpg, *.png, backup/*.zip)"/>
                    <Button x:Name="ListRemoteButton" Grid.Column="2" Content="列出文件"
                            Width="80" Margin="10,0,0,0" Click="ListRemoteButton_Click"/>
                    <Button x:Name="DownloadButton" Grid.Column="3" Content="下载"
                            Width="80" Margin="10,0,0,0" IsEnabled="{Binding CanDownload, Mode=OneWay}"
                            Click="DownloadButton_Click"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- 同步模式 + 操作按钮 -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="同步模式:" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <RadioButton x:Name="Mode0Radio" Content="仅上传新增" GroupName="SyncMode" Tag="0"/>
                <RadioButton x:Name="Mode1Radio" Content="上传+更新（修改时间不同的文件）" GroupName="SyncMode" Tag="1" IsChecked="True"/>
                <RadioButton x:Name="Mode2Radio" Content="上传后删除本地" GroupName="SyncMode" Tag="2"/>
            </StackPanel>

            <Button x:Name="ScanButton" Grid.Column="1" Content="{Binding ScanButtonContent, Mode=OneWay}"
                    Width="120" Margin="0,0,10,0" IsEnabled="{Binding CanScan, Mode=OneWay}"/>
            <Button x:Name="SyncButton" Grid.Column="2" Content="{Binding SyncButtonContent, Mode=OneWay}"
                    Width="120" Margin="0,0,10,0" IsEnabled="{Binding CanSync, Mode=OneWay}"/>
            <Button x:Name="CancelButton" Grid.Column="3" Content="取消"
                    Width="80" IsCancel="True" IsEnabled="{Binding CanCancel, Mode=OneWay}"/>
        </Grid>

        <!-- 进度条 -->
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                         Height="20" Minimum="0" Maximum="100"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 日志区域 -->
        <GroupBox Grid.Row="5" Header="操作日志" Padding="10">
            <ListBox x:Name="LogListBox" ItemsSource="{Binding Logs}" BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- 底部说明 -->
        <TextBlock Grid.Row="6" Text="提示：配置对象存储参数，选择本地目录，点击&quot;扫描&quot;查看待同步文件，确认后点击&quot;开始同步&quot;将文件上传到对象存储。"
                   Foreground="#666666" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
    </Grid>
</Window>
