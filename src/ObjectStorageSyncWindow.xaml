<hc:Window x:Class="file_sync.ObjectStorageSyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="同步到对象存储" Height="550" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource RegionBrush}"
        Icon="icon.ico">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 存储配置 -->
        <hc:Card Grid.Row="0" Margin="0,0,0,10" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 第一行: 存储类型 + Bucket + Endpoint -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="存储类型:" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                    <ComboBox x:Name="StorageTypeComboBox" SelectedIndex="{Binding StorageType}"
                              Width="140" Margin="0,0,8,0"
                              SelectionChanged="StorageTypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="AWS S3"/>
                        <ComboBoxItem Content="阿里云 OSS"/>
                        <ComboBoxItem Content="腾讯云 COS"/>
                        <ComboBoxItem Content="MinIO"/>
                    </ComboBox>
                    <TextBlock x:Name="EndpointHint" Text="s3.amazonaws.com"
                               VerticalAlignment="Center" Opacity="0.6"/>
                </StackPanel>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Bucket:" VerticalAlignment="Center"/>
                <hc:TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Bucket, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Endpoint:" VerticalAlignment="Center"/>
                <hc:TextBox Grid.Row="0" Grid.Column="5" Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- 第二行: AccessKey + SecretKey -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="AccessKey:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="AccessKeyBox" Margin="0,8,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="SecretKey:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <PasswordBox Grid.Row="1" Grid.Column="3" x:Name="SecretKeyBox" Margin="0,8,8,0"/>
            </Grid>
        </hc:Card>

        <!-- 上传配置 -->
        <hc:Card Grid.Row="1" Margin="0,0,0,10" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 本地目录 + 前缀 + 浏览按钮 -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="本地目录:" VerticalAlignment="Center"/>
                    <hc:TextBox Grid.Column="1" Text="{Binding LocalDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Column="2" Text="前缀:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <hc:TextBox Grid.Column="3" Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}" Margin="8,0,0,0"/>
                    <Button Grid.Column="4" x:Name="BrowseButton" Content="浏览..." Width="70" Margin="8,0,0,0"/>
                </Grid>

                <!-- 同步模式 + 按钮 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="同步模式:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                        <RadioButton x:Name="Mode0Radio" Content="仅上传新增" GroupName="SyncMode" Tag="0" Margin="0,0,8,0"/>
                        <RadioButton x:Name="Mode1Radio" Content="上传+更新" GroupName="SyncMode" Tag="1" IsChecked="True" Margin="0,0,8,0"/>
                        <RadioButton x:Name="Mode2Radio" Content="上传后删除" GroupName="SyncMode" Tag="2"/>
                    </StackPanel>

                    <Button Grid.Column="1" x:Name="ScanButton" Content="{Binding ScanButtonContent, Mode=OneWay}"
                            Style="{StaticResource ButtonPrimary}" Width="80" Margin="0,0,8,0"
                            IsEnabled="{Binding CanScan, Mode=OneWay}"/>
                    <Button Grid.Column="2" x:Name="SyncButton" Content="{Binding SyncButtonContent, Mode=OneWay}"
                            Style="{StaticResource ButtonSuccess}" Width="80" Margin="0,0,8,0"
                            IsEnabled="{Binding CanSync, Mode=OneWay}"/>
                    <Button Grid.Column="3" x:Name="CancelButton" Content="取消"
                            Style="{StaticResource ButtonDanger}" Width="60"
                            IsEnabled="{Binding CanCancel, Mode=OneWay}"/>
                </Grid>
            </Grid>
        </hc:Card>

        <!-- 进度条 -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                             Maximum="100" Minimum="0"
                             IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                             Height="20" Margin="0,0,0,0"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 日志区域 -->
        <hc:Card Grid.Row="3" Padding="8">
            <ListBox x:Name="LogListBox" ItemsSource="{Binding Logs}" BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"
                                   FontSize="12"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </hc:Card>
    </Grid>
</hc:Window>
