<Window x:Class="file_sync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:file_sync.ViewModels"
        mc:Ignorable="d"
        Title="文件迁移工具" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Icon="icon.ico">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 目录选择区域 -->
        <GroupBox Grid.Row="0" Header="目录选择" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 源目录 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="原目录:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding SourceDirectory, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="False" Background="#FAFAFA"/>
                    <Button x:Name="BrowseSourceButton" Grid.Column="2" Content="浏览..."
                            Width="80" Margin="10,0,0,0"/>
                </Grid>

                <!-- 目标目录 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="目标目录:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="False" Background="#FAFAFA"/>
                    <Button x:Name="BrowseTargetButton" Grid.Column="2" Content="浏览..."
                            Width="80" Margin="10,0,0,0"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- 操作按钮区域 -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="White" Padding="15,8" CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="已扫描：" Margin="0,0,15,0">
                            <Run FontWeight="Bold" Foreground="#0078D4" Text="{Binding TotalScanned, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="待删除：" Margin="0,0,15,0">
                            <Run FontWeight="Bold" Foreground="#D13438" Text="{Binding ToDeleteCount, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="待移动：">
                            <Run FontWeight="Bold" Foreground="#107C10" Text="{Binding ToMoveCount, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Button x:Name="ScanButton" Grid.Column="1" Content="{Binding ScanButtonContent, Mode=OneWay}"
                    Width="120" Margin="0,0,10,0" IsEnabled="{Binding CanScan, Mode=OneWay}"/>
            <Button x:Name="MigrateButton" Grid.Column="2" Content="{Binding MigrateButtonContent, Mode=OneWay}"
                    Width="120" Margin="0,0,10,0" IsEnabled="{Binding CanMigrate, Mode=OneWay}"/>
            <Button Grid.Column="3" Content="取消" Command="{Binding CancelCommand}"
                    Width="80" IsCancel="True"/>
        </Grid>

        <!-- 进度条 -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                         Height="20" Minimum="0" Maximum="100"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 日志区域 -->
        <GroupBox Grid.Row="3" Header="操作日志" Padding="10">
            <ListBox ItemsSource="{Binding Logs}" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- 底部说明 -->
        <TextBlock Grid.Row="4" Text="提示：先选择原目录和目标目录，点击&apos;扫描目录&apos;进行对比，确认无误后点击&apos;开始迁移&apos;执行操作。"
                   Foreground="#666666" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
    </Grid>
</Window>
