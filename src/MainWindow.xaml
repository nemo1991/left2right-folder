<hc:Window x:Class="file_sync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:file_sync.ViewModels"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="文件迁移工具" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource RegionBrush}"
        Icon="icon.ico">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 目录选择区域 -->
        <hc:Card Grid.Row="0" Margin="0,0,0,10" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 源目录 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="原目录:" VerticalAlignment="Center"/>
                <hc:TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SourceDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <Button Grid.Row="0" Grid.Column="2" x:Name="BrowseSourceButton" Content="浏览..."
                        Width="70"/>

                <!-- 目标目录 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="目标目录:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <hc:TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,8,0"/>
                <Button Grid.Row="1" Grid.Column="2" x:Name="BrowseTargetButton" Content="浏览..."
                        Width="70" Margin="0,8,0,0"/>
            </Grid>
        </hc:Card>

        <!-- 操作按钮区域 -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SecondaryRegionBrush}"
                    CornerRadius="4" Padding="12,6" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="已扫描:" Margin="0,0,12,0">
                        <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Text="{Binding TotalScanned, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="待删除:" Margin="0,0,12,0">
                        <Run FontWeight="Bold" Foreground="#D13438" Text="{Binding ToDeleteCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="待移动:" Margin="0,0,12,0">
                        <Run FontWeight="Bold" Foreground="#107C10" Text="{Binding ToMoveCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="冲突:">
                        <Run FontWeight="Bold" Foreground="#FF6B00" Text="{Binding ConflictCount, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Button Grid.Column="1" x:Name="ScanButton" Content="{Binding ScanButtonContent, Mode=OneWay}"
                    Style="{StaticResource ButtonPrimary}" Width="80" Margin="0,0,8,0"/>
            <Button Grid.Column="2" x:Name="MigrateButton" Content="{Binding MigrateButtonContent, Mode=OneWay}"
                    Style="{StaticResource ButtonSuccess}" Width="80" Margin="0,0,8,0"/>
            <Button Grid.Column="3" x:Name="CancelButton" Content="取消"
                    Style="{StaticResource ButtonDanger}" Width="60"/>
        </Grid>

        <!-- 进度条 -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                             Maximum="100" Minimum="0"
                             IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                             Height="20" Margin="0,0,0,0"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 日志区域 -->
        <hc:Card Grid.Row="3" Padding="8">
            <ListBox x:Name="LogListBox" ItemsSource="{Binding Logs}" BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"
                                   FontSize="12"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </hc:Card>
    </Grid>
</hc:Window>
