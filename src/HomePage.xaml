<Window x:Class="file_sync.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="文件管理工具" Height="580" Width="780"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Icon="icon.ico">

    <Window.Resources>
        <!-- 卡片样式 -->
        <Style x:Key="FeatureCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 功能按钮样式 -->
        <Style x:Key="FeatureButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,40">
            <!-- 图标 -->
            <Border Background="{StaticResource PrimaryBrush}" CornerRadius="16" Width="80" Height="80"
                    HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="📁" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="文件管理工具" FontSize="32" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="选择要使用的功能" FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 功能卡片区域 -->
        <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="10">
            <!-- 文件迁移 -->
            <Border Style="{StaticResource FeatureCard}" Margin="10">
                <Button Style="{StaticResource FeatureButton}" Click="FileMigrationButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="8">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="文件迁移" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="对比两个目录，将相同文件删除&#x0a;不同文件移动到目标目录"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 按年份迁移 -->
            <Border Style="{StaticResource FeatureCard}" Margin="10">
                <Button Style="{StaticResource FeatureButton}" Click="YearFilterButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="8">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="按年份迁移" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="按修改年份筛选文件&#x0a;批量移动到年份子目录"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 同步到对象存储 -->
            <Border Style="{StaticResource FeatureCard}" Margin="10">
                <Button Style="{StaticResource FeatureButton}" Click="ObjectStorageSyncButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="8">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="☁️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="同步到对象存储" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="将本地文件同步到&#x0a;S3/OSS/COS 对象存储"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 从对象存储下载 -->
            <Border Style="{StaticResource FeatureCard}" Margin="10">
                <Button Style="{StaticResource FeatureButton}" Click="S3DownloadButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="8">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📥" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="从对象存储下载" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="从对象存储下载文件&#x0a;支持通配符匹配"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>
        </UniformGrid>

        <!-- 底部 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <TextBlock Text="版本 1.2.0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
