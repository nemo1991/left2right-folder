<hc:Window x:Class="file_sync.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="文件管理工具" Height="480" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource RegionBrush}"
        Icon="icon.ico">

    <Window.Resources>
        <Geometry x:Key="FolderIcon">M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z</Geometry>
        <Geometry x:Key="CompareIcon">M19,18L14,13H10V11H14L19,6V4H21V18M3,4V6H21V4H3M3,20V18H21V20H3M3,14V12H21V14H3Z</Geometry>
        <Geometry x:Key="CalendarIcon">M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3H18V1M17,12H12V17H17V12Z</Geometry>
        <Geometry x:Key="CloudUploadIcon">M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.04M19,18H6A4,4 0 0,1 2,14C2,11.95 3.53,10.24 5.56,10.03L6.63,9.92L7.13,8.97C8.5,7 10.62,6 13,6A7,7 0 0,1 20,13V15L19,16V18M12,13L8,17H11V22H13V17H16L12,13Z</Geometry>
        <Geometry x:Key="CloudDownloadIcon">M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.04M19,18H6A4,4 0 0,1 2,14C2,11.95 3.53,10.24 5.56,10.03L6.63,9.92L7.13,8.97C8.5,7 10.62,6 13,6A7,7 0 0,1 20,13V15L19,16V18M10,18V14H7L12,9L17,14H14V18H10Z</Geometry>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 功能列表 - 垂直排列 -->
        <StackPanel Grid.Row="1" Margin="20,0" HorizontalAlignment="Left">
            <!-- 文件迁移 -->
            <Border Margin="0,0,0,12" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}"  Click="FileMigrationButton_Click"
                        HorizontalAlignment="Left" Background="Transparent" BorderThickness="0"
                        Padding="20,16">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                        <Border Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="8" Width="48" Height="48" Margin="0,0,16,0"
                                VerticalAlignment="Top">
                            <Path Data="{StaticResource CompareIcon}" Fill="White" Width="24" Height="24"
                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0"/>
                        </Border>
                        <StackPanel VerticalAlignment="Top" Width="300">
                            <TextBlock Text="文件迁移" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="对比两个目录，将相同文件删除、不同文件移动到目标目录"
                                       FontSize="12" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 按年份迁移 -->
            <Border Margin="0,0,0,12" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="YearFilterButton_Click"
                        HorizontalAlignment="Left" Background="Transparent" BorderThickness="0"
                        Padding="20,16">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                        <Border Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="8" Width="48" Height="48" Margin="0,0,16,0"
                                VerticalAlignment="Top">
                            <Path Data="{StaticResource CalendarIcon}" Fill="White" Width="24" Height="24"
                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0"/>
                        </Border>
                        <StackPanel VerticalAlignment="Top" Width="300">
                            <TextBlock Text="按年份迁移" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="按修改年份筛选文件，批量移动到目标目录的年份子目录"
                                       FontSize="12" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 同步到对象存储 -->
            <Border Margin="0,0,0,12" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="ObjectStorageSyncButton_Click"
                        HorizontalAlignment="Left" Background="Transparent" BorderThickness="0"
                        Padding="20,16">
                    <StackPanel Orientation="Horizontal"  VerticalAlignment="Top">
                        <Border Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="8" Width="48" Height="48" Margin="0,0,16,0"
                                VerticalAlignment="Top">
                            <Path Data="{StaticResource CloudUploadIcon}" Fill="White" Width="24" Height="24"
                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0"/>
                        </Border>
                        <StackPanel VerticalAlignment="Top" Width="300">
                            <TextBlock Text="同步到对象存储" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="将本地文件同步到 S3/OSS/COS 兼容的对象存储服务"
                                       FontSize="12" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 从对象存储下载 -->
            <Border Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="S3DownloadButton_Click"
                        HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0"
                        Padding="20,16">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                        <Border Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="8" Width="48" Height="48" Margin="0,0,16,0"
                                VerticalAlignment="Top">
                            <Path Data="{StaticResource CloudDownloadIcon}" Fill="White" Width="24" Height="24"
                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0"/>
                        </Border>
                        <StackPanel VerticalAlignment="Top">
                            <TextBlock Text="从对象存储下载" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="从 S3/OSS/COS 兼容的对象存储服务下载文件，支持通配符匹配"
                                       FontSize="12" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </Border>
        </StackPanel>

        <!-- 底部 -->
        <TextBlock Grid.Row="2" Text="版本 1.2.0" FontSize="12" Opacity="0.5"
                   HorizontalAlignment="Center" Margin="0,20,0,0"/>
    </Grid>
</hc:Window>
