<Window x:Class="file_sync.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="文件管理工具" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Icon="icon.ico">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,40">
            <materialDesign:PackIcon Kind="FolderMultiple" Width="64" Height="64" HorizontalAlignment="Center"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            <TextBlock Text="文件管理工具" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,16,0,8"
                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            <TextBlock Text="选择要使用的功能" FontSize="14" HorizontalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
        </StackPanel>

        <!-- 功能列表 - 使用 UniformGrid 实现卡片式布局 -->
        <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="20">
            <!-- 文件迁移 -->
            <materialDesign:Card Margin="10" Padding="20" UniformCornerRadius="16"
                                 materialDesign:ElevationAssist.Elevation="Dp4">
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Click="FileMigrationButton_Click" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Height="Auto" Padding="0">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="FileCompare" Width="48" Height="48"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="文件迁移" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="对比两个目录，将相同文件删除、不同文件移动到目标目录"
                                   FontSize="12" TextWrapping="Wrap" Opacity="0.7"/>
                    </StackPanel>
                </Button>
            </materialDesign:Card>

            <!-- 按年份迁移 -->
            <materialDesign:Card Margin="10" Padding="20" UniformCornerRadius="16"
                                 materialDesign:ElevationAssist.Elevation="Dp4">
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Click="YearFilterButton_Click" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Height="Auto" Padding="0">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CalendarClock" Width="48" Height="48"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="按年份迁移" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="按修改年份筛选文件，批量移动到目标目录的年份子目录"
                                   FontSize="12" TextWrapping="Wrap" Opacity="0.7"/>
                    </StackPanel>
                </Button>
            </materialDesign:Card>

            <!-- 同步到对象存储 -->
            <materialDesign:Card Margin="10" Padding="20" UniformCornerRadius="16"
                                 materialDesign:ElevationAssist.Elevation="Dp4">
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Click="ObjectStorageSyncButton_Click" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Height="Auto" Padding="0">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CloudUpload" Width="48" Height="48"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="同步到对象存储" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="将本地文件同步到 S3/OSS/COS 兼容的对象存储服务"
                                   FontSize="12" TextWrapping="Wrap" Opacity="0.7"/>
                    </StackPanel>
                </Button>
            </materialDesign:Card>

            <!-- 从对象存储下载 -->
            <materialDesign:Card Margin="10" Padding="20" UniformCornerRadius="16"
                                 materialDesign:ElevationAssist.Elevation="Dp4">
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Click="S3DownloadButton_Click" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Height="Auto" Padding="0">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="CloudDownload" Width="48" Height="48"
                                                 Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="从对象存储下载" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="从 S3/OSS/COS 兼容的对象存储服务下载文件，支持通配符匹配"
                                   FontSize="12" TextWrapping="Wrap" Opacity="0.7"/>
                    </StackPanel>
                </Button>
            </materialDesign:Card>
        </UniformGrid>

        <!-- 底部 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <materialDesign:PackIcon Kind="Github" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.5"/>
            <TextBlock Text="版本 1.2.0" FontSize="12" Opacity="0.5" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
