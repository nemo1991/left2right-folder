<hc:Window x:Class="file_sync.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="文件管理工具" Height="600" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource RegionBrush}"
        Icon="icon.ico">

    <Window.Resources>
        <!-- 文件夹图标 -->
        <Geometry x:Key="FolderIcon">M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z</Geometry>
        <!-- 对比图标 -->
        <Geometry x:Key="CompareIcon">M19,18L14,13H10V11H14L19,6V4H21V18M3,4V6H21V4H3M3,20V18H21V20H3M3,14V12H21V14H3Z</Geometry>
        <!-- 日历图标 -->
        <Geometry x:Key="CalendarIcon">M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3H18V1M17,12H12V17H17V12Z</Geometry>
        <!-- 上传图标 -->
        <Geometry x:Key="CloudUploadIcon">M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.04M19,18H6A4,4 0 0,1 2,14C2,11.95 3.53,10.24 5.56,10.03L6.63,9.92L7.13,8.97C8.5,7 10.62,6 13,6A7,7 0 0,1 20,13V15L19,16V18M12,13L8,17H11V22H13V17H16L12,13Z</Geometry>
        <!-- 下载图标 -->
        <Geometry x:Key="CloudDownloadIcon">M19.35,10.04C18.67,6.59 15.64,4 12,4C9.11,4 6.6,5.64 5.35,8.04C2.34,8.36 0,10.91 0,14A6,6 0 0,0 6,20H19A5,5 0 0,0 24,15C24,12.36 21.95,10.22 19.35,10.04M19,18H6A4,4 0 0,1 2,14C2,11.95 3.53,10.24 5.56,10.03L6.63,9.92L7.13,8.97C8.5,7 10.62,6 13,6A7,7 0 0,1 20,13V15L19,16V18M10,18V14H7L12,9L17,14H14V18H10Z</Geometry>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,30">
            <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="16" Width="80" Height="80"
                    HorizontalAlignment="Center" Margin="0,0,0,16">
                <Path Data="{StaticResource FolderIcon}" Fill="White" Width="40" Height="40"
                      Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="文件管理工具" FontSize="32" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="选择要使用的功能" FontSize="14" Opacity="0.6"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 功能卡片区域 -->
        <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="10">
            <!-- 文件迁移 -->
            <Border Margin="8" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="FileMigrationButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Path Data="{StaticResource CompareIcon}" Fill="{DynamicResource PrimaryBrush}"
                              Width="48" Height="48" Stretch="Uniform" Margin="0,0,0,16"/>
                        <TextBlock Text="文件迁移" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="对比两个目录，将相同文件删除&#x0a;不同文件移动到目标目录"
                                   FontSize="12" Opacity="0.6" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 按年份迁移 -->
            <Border Margin="8" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="YearFilterButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Path Data="{StaticResource CalendarIcon}" Fill="{DynamicResource PrimaryBrush}"
                              Width="48" Height="48" Stretch="Uniform" Margin="0,0,0,16"/>
                        <TextBlock Text="按年份迁移" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="按修改年份筛选文件&#x0a;批量移动到年份子目录"
                                   FontSize="12" Opacity="0.6" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 同步到对象存储 -->
            <Border Margin="8" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="ObjectStorageSyncButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Path Data="{StaticResource CloudUploadIcon}" Fill="{DynamicResource PrimaryBrush}"
                              Width="48" Height="48" Stretch="Uniform" Margin="0,0,0,16"/>
                        <TextBlock Text="同步到对象存储" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="将本地文件同步到&#x0a;S3/OSS/COS 对象存储"
                                   FontSize="12" Opacity="0.6" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 从对象存储下载 -->
            <Border Margin="8" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="S3DownloadButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Path Data="{StaticResource CloudDownloadIcon}" Fill="{DynamicResource PrimaryBrush}"
                              Width="48" Height="48" Stretch="Uniform" Margin="0,0,0,16"/>
                        <TextBlock Text="从对象存储下载" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="从对象存储下载文件&#x0a;支持通配符匹配"
                                   FontSize="12" Opacity="0.6" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>
        </UniformGrid>

        <!-- 底部 -->
        <TextBlock Grid.Row="2" Text="版本 1.2.0" FontSize="12" Opacity="0.5"
                   HorizontalAlignment="Center" Margin="0,20,0,0"/>
    </Grid>
</hc:Window>
