<hc:Window x:Class="file_sync.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="文件管理工具" Height="600" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource RegionBrush}"
        Icon="icon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,30">
            <TextBlock Text="📁" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="文件管理工具" FontSize="32" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="选择要使用的功能" FontSize="14" Opacity="0.6"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 功能卡片区域 -->
        <UniformGrid Grid.Row="1" Columns="2" Rows="2" Margin="10">
            <!-- 文件迁移 -->
            <Border Margin="8" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="FileMigrationButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="文件迁移" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="对比两个目录，将相同文件删除&#x0a;不同文件移动到目标目录"
                                   FontSize="12" Opacity="0.6" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 按年份迁移 -->
            <Border Margin="8" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="YearFilterButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="按年份迁移" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="按修改年份筛选文件&#x0a;批量移动到年份子目录"
                                   FontSize="12" Opacity="0.6" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 同步到对象存储 -->
            <Border Margin="8" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="ObjectStorageSyncButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="☁️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="同步到对象存储" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="将本地文件同步到&#x0a;S3/OSS/COS 对象存储"
                                   FontSize="12" Opacity="0.6" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- 从对象存储下载 -->
            <Border Margin="8" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Button Style="{StaticResource ButtonCustom}" Click="S3DownloadButton_Click"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📥" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="从对象存储下载" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="从对象存储下载文件&#x0a;支持通配符匹配"
                                   FontSize="12" Opacity="0.6" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Button>
            </Border>
        </UniformGrid>

        <!-- 底部 -->
        <TextBlock Grid.Row="2" Text="版本 1.2.0" FontSize="12" Opacity="0.5"
                   HorizontalAlignment="Center" Margin="0,20,0,0"/>
    </Grid>
</hc:Window>
