<Window x:Class="file_sync.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="文件管理工具" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Icon="icon.ico">

    <Window.Resources>
        <Style x:Key="FeatureButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F7FF"/>
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="文件管理工具" FontSize="28" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
            <TextBlock Text="选择要使用的功能" FontSize="14" Foreground="#666666"/>
        </StackPanel>

        <!-- 功能列表 -->
        <StackPanel Grid.Row="1">
            <Button x:Name="FileMigrationButton" Style="{StaticResource FeatureButton}"
                    Click="FileMigrationButton_Click" HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="文件迁移" FontWeight="Bold" FontSize="18"/>
                    <TextBlock Text="对比两个目录，将相同文件删除、不同文件移动到目标目录"
                               FontSize="13" Foreground="#666666" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Button>

            <Button x:Name="YearFilterButton" Style="{StaticResource FeatureButton}"
                    Click="YearFilterButton_Click" HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="按年份迁移文件" FontWeight="Bold" FontSize="18"/>
                    <TextBlock Text="按修改年份筛选文件，批量移动到目标目录中对应的年份子目录"
                               FontSize="13" Foreground="#666666" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Button>

            <Button x:Name="ObjectStorageSyncButton" Style="{StaticResource FeatureButton}"
                    Click="ObjectStorageSyncButton_Click" HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="同步到对象存储" FontWeight="Bold" FontSize="18"/>
                    <TextBlock Text="将本地文件同步到 S3/OSS/COS 兼容的对象存储服务"
                               FontSize="13" Foreground="#666666" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- 底部 -->
        <TextBlock Grid.Row="2" Text="版本 1.2.0" Foreground="#999999" FontSize="12" HorizontalAlignment="Center"/>
    </Grid>
</Window>
