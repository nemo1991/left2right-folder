<Window x:Class="file_sync.YearFilterMigrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:file_sync.ViewModels"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="按年份迁移文件" Height="680" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        Icon="icon.ico">

    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 返回主页 -->
        <Button x:Name="BackButton" Grid.Row="0" Content="← 返回主页"
                Background="Transparent" Foreground="#0078D4" BorderThickness="0"
                Padding="0" Margin="0,0,0,10" HorizontalAlignment="Left"
                Cursor="Hand" FontSize="13" Click="BackButton_Click"/>

        <!-- 目录选择区域 -->
        <GroupBox Grid.Row="1" Header="目录与年份选择" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 源目录 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="源目录:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding SourceDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button x:Name="BrowseSourceButton" Grid.Column="2" Content="浏览..."
                            Width="80" Margin="10,0,0,0"/>
                </Grid>

                <!-- 年份选择 -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="迁移年份:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="YearTextBox" Grid.Column="1" Text="{Binding YearText, UpdateSourceTrigger=PropertyChanged}"
                             TextAlignment="Center" FontSize="14" FontWeight="Bold"
                             MaxLength="4"/>
                    <Button Grid.Column="2" x:Name="YearDropdownButton"
                            Width="32" Height="32" Margin="4,0,0,0"
                            Cursor="Hand" Click="YearDropdownButton_Click"
                            Background="Transparent" BorderThickness="0"
                            Padding="0" HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" Style="{x:Null}">
                        <Path Data="M0,0 L10,0 L5,8 Z" Fill="#0078D4"
                              Width="10" Height="8" Stretch="Fill"/>
                    </Button>
                    <TextBlock Grid.Column="3" Text="{Binding YearInfoText}"
                               VerticalAlignment="Center" Margin="15,0,0,0" Foreground="{Binding YearValidationColor}" FontSize="13"/>
                </Grid>

                <!-- 目标目录 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="目标目录:" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    <TextBox Grid.Column="1" Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button x:Name="BrowseTargetButton" Grid.Column="2" Content="浏览..."
                            Width="80" Margin="10,0,0,0"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- 年份下拉弹窗 -->
        <Popup x:Name="YearDropdownPopup" Grid.Row="0" PlacementTarget="{Binding ElementName=YearDropdownButton}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
               PopupAnimation="Slide">
            <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                    MaxHeight="300" Margin="2">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" Opacity="0.3" BlurRadius="6"/>
                </Border.Effect>
                <ListBox x:Name="YearListBox" BorderThickness="0"
                         DisplayMemberPath="YearText" SelectedValuePath="Year"
                         MaxHeight="300">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
        </Popup>

        <!-- 操作按钮区域 -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="White" Padding="15,8" CornerRadius="4" BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="待迁移：" Margin="0,0,15,0">
                            <Run FontWeight="Bold" Foreground="#107C10" Text="{Binding ToMoveCount, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="总大小：" Margin="0,0,15,0" Visibility="{Binding TotalSizeVisibility, Mode=OneWay}">
                            <Run FontWeight="Bold" Foreground="#0078D4" Text="{Binding TotalSizeText, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="目标子目录：" Margin="0,0,15,0">
                            <Run FontWeight="Bold" Foreground="#0078D4" Text="{Binding TargetSubDirInfo, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="警告：" Margin="0,0,15,0" Visibility="{Binding WarningVisibility, Mode=OneWay}">
                            <Run FontWeight="Bold" Foreground="#FF6B00" Text="{Binding WarningText, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Button x:Name="ScanButton" Grid.Column="1" Content="{Binding ScanButtonContent, Mode=OneWay}"
                    Width="120" Margin="0,0,10,0" IsEnabled="{Binding CanScan, Mode=OneWay}"/>
            <Button x:Name="MigrateButton" Grid.Column="2" Content="{Binding MigrateButtonContent, Mode=OneWay}"
                    Width="120" Margin="0,0,10,0" IsEnabled="{Binding CanMigrate, Mode=OneWay}"/>
            <Button x:Name="CancelButton" Grid.Column="3" Content="取消"
                    Width="80" IsCancel="True" IsEnabled="{Binding CanCancel, Mode=OneWay}"/>
        </Grid>

        <!-- 进度条 -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                         Height="20" Minimum="0" Maximum="100"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 日志区域 -->
        <GroupBox Grid.Row="4" Header="操作日志" Padding="10">
            <ListBox x:Name="LogListBox" ItemsSource="{Binding Logs}" BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- 底部说明 -->
        <TextBlock Grid.Row="5" Text="提示：选择源目录、目标目录和年份，点击&quot;扫描&quot;查找该年份修改的文件，确认后点击&quot;开始迁移&quot;将文件移动至目标目录的年份子目录中。"
                   Foreground="#666666" FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap"/>
    </Grid>
</Window>
