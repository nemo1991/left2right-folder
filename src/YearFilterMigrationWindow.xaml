<hc:Window x:Class="file_sync.YearFilterMigrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:file_sync.ViewModels"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="按年份迁移文件" Height="520" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource RegionBrush}"
        Icon="icon.ico">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 目录与年份选择 -->
        <hc:Card Grid.Row="0" Margin="0,0,0,10" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 源目录 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="源目录:" VerticalAlignment="Center" Margin="5"/>
                <hc:TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SourceDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="0" Grid.Column="2" x:Name="BrowseSourceButton" Content="浏览..."
                        Width="70" Margin="5"/>

                <!-- 年份选择 -->
                <TextBlock Grid.Row="0" Grid.Column="3" Text="迁移年份:" VerticalAlignment="Center" Margin="5"/>
                <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal">
                    <hc:TextBox x:Name="YearTextBox" Text="{Binding YearText, UpdateSourceTrigger=PropertyChanged}"
                               FontSize="14" FontWeight="Bold" MaxLength="4" Width="80" Margin="5"/>
                    <Button x:Name="YearDropdownButton" Width="28" Height="28" Margin="5"
                            Click="YearDropdownButton_Click">
                        <Path Data="M0,0 L10,0 L5,8 Z" Fill="{DynamicResource PrimaryBrush}"
                              Width="10" Height="8" Stretch="Fill"/>
                    </Button>
                    <TextBlock Text="{Binding YearInfoText}" VerticalAlignment="Center"
                               Foreground="{Binding YearValidationColor}" FontSize="12" Margin="5"/>
                </StackPanel>

                <!-- 目标目录 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="目标目录:" VerticalAlignment="Center" Margin="5"/>
                <hc:TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                <Button Grid.Row="1" Grid.Column="2" x:Name="BrowseTargetButton" Content="浏览..."
                        Width="70" Margin="5"/>
            </Grid>
        </hc:Card>

        <!-- 年份下拉弹窗 -->
        <Popup x:Name="YearDropdownPopup" PlacementTarget="{Binding ElementName=YearDropdownButton}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
               PopupAnimation="Slide">
            <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    MaxHeight="250" Margin="2">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" Opacity="0.3" BlurRadius="6"/>
                </Border.Effect>
                <ListBox x:Name="YearListBox" BorderThickness="0"
                         DisplayMemberPath="YearText" SelectedValuePath="Year"
                         MaxHeight="250">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,5"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
        </Popup>

        <!-- 操作按钮区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SecondaryRegionBrush}"
                    CornerRadius="4" Padding="12,6" Margin="5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="待迁移:" Margin="0,0,10,0">
                        <Run FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Text="{Binding ToMoveCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="总大小:" Margin="0,0,10,0" Visibility="{Binding TotalSizeVisibility, Mode=OneWay}">
                        <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Text="{Binding TotalSizeText, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="目标:" Margin="0,0,10,0">
                        <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Text="{Binding TargetSubDirInfo, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="警告:" Visibility="{Binding WarningVisibility, Mode=OneWay}">
                        <Run FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" Text="{Binding WarningText, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Button Grid.Column="1" x:Name="ScanButton" Content="{Binding ScanButtonContent, Mode=OneWay}"
                    Style="{StaticResource ButtonPrimary}" Width="80" Margin="5"/>
            <Button Grid.Column="2" x:Name="MigrateButton" Content="{Binding MigrateButtonContent, Mode=OneWay}"
                    Style="{StaticResource ButtonSuccess}" Width="80" Margin="5"/>
            <Button Grid.Column="3" x:Name="CancelButton" Content="取消"
                    Style="{StaticResource ButtonDanger}" Width="80" Margin="5"/>
        </Grid>

        <!-- 进度条 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                 Maximum="100" Minimum="0"
                 IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                 Height="20" Margin="5"/>

            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="5"
                       TextTrimming="CharacterEllipsis"/>
            
        </Grid>

        <!-- 日志区域 -->
        <hc:Card Grid.Row="3" Padding="8">
            <ListBox x:Name="LogListBox" ItemsSource="{Binding Logs}" BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"
                                   FontSize="12"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </hc:Card>
    </Grid>
</hc:Window>
