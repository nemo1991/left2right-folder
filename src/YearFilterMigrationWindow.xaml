<hc:Window x:Class="file_sync.YearFilterMigrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:file_sync.ViewModels"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="按年份迁移文件" Height="750" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource RegionBrush}"
        Icon="icon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 返回主页 -->
        <Button x:Name="BackButton" Grid.Row="0" Content="返回主页"
                Style="{StaticResource ButtonDefault}" HorizontalAlignment="Left"
                Margin="0,0,0,15" Click="BackButton_Click"/>

        <!-- 目录选择区域 -->
        <hc:Card Grid.Row="1" Margin="0,0,0,15" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 源目录 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="源目录:" VerticalAlignment="Center"/>
                    <hc:TextBox Grid.Column="1" Text="{Binding SourceDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button x:Name="BrowseSourceButton" Grid.Column="2" Content="浏览..."
                            Width="80" Margin="10,0,0,0"/>
                </Grid>

                <!-- 年份选择 -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="迁移年份:" VerticalAlignment="Center"/>
                    <hc:TextBox x:Name="YearTextBox" Grid.Column="1"
                               Text="{Binding YearText, UpdateSourceTrigger=PropertyChanged}"
                               FontSize="14" FontWeight="Bold" MaxLength="4"/>
                    <Button Grid.Column="2" x:Name="YearDropdownButton"
                            Width="32" Height="32" Margin="4,0,0,0"
                            Click="YearDropdownButton_Click">
                        <Path Data="M0,0 L10,0 L5,8 Z" Fill="{DynamicResource PrimaryBrush}"
                              Width="10" Height="8" Stretch="Fill"/>
                    </Button>
                    <TextBlock Grid.Column="3" Text="{Binding YearInfoText}"
                               VerticalAlignment="Center" Margin="15,0,0,0"
                               Foreground="{Binding YearValidationColor}" FontSize="13"/>
                </Grid>

                <!-- 目标目录 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="目标目录:" VerticalAlignment="Center"/>
                    <hc:TextBox Grid.Column="1" Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button x:Name="BrowseTargetButton" Grid.Column="2" Content="浏览..."
                            Width="80" Margin="10,0,0,0"/>
                </Grid>
            </Grid>
        </hc:Card>

        <!-- 年份下拉弹窗 -->
        <Popup x:Name="YearDropdownPopup" PlacementTarget="{Binding ElementName=YearDropdownButton}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
               PopupAnimation="Slide">
            <Border Background="White" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    MaxHeight="300" Margin="2">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" Opacity="0.3" BlurRadius="6"/>
                </Border.Effect>
                <ListBox x:Name="YearListBox" BorderThickness="0"
                         DisplayMemberPath="YearText" SelectedValuePath="Year"
                         MaxHeight="300">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
        </Popup>

        <!-- 操作按钮区域 -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SecondaryRegionBrush}"
                    CornerRadius="4" Padding="15,8" Margin="0,0,15,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="待迁移：" Margin="0,0,15,0">
                        <Run FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Text="{Binding ToMoveCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="总大小：" Margin="0,0,15,0" Visibility="{Binding TotalSizeVisibility, Mode=OneWay}">
                        <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Text="{Binding TotalSizeText, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="目标子目录：" Margin="0,0,15,0">
                        <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Text="{Binding TargetSubDirInfo, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="警告：" Margin="0,0,15,0" Visibility="{Binding WarningVisibility, Mode=OneWay}">
                        <Run FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" Text="{Binding WarningText, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Button x:Name="ScanButton" Grid.Column="1" Content="{Binding ScanButtonContent, Mode=OneWay}"
                    Style="{StaticResource ButtonPrimary}" Width="100" Margin="0,0,10,0"/>
            <Button x:Name="MigrateButton" Grid.Column="2" Content="{Binding MigrateButtonContent, Mode=OneWay}"
                    Style="{StaticResource ButtonSuccess}" Width="100" Margin="0,0,10,0"/>
            <Button x:Name="CancelButton" Grid.Column="3" Content="取消"
                    Style="{StaticResource ButtonDanger}" Width="80"/>
        </Grid>

        <!-- 进度条 -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <hc:CircleProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                                 ShowText="False" Height="24"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 日志区域 -->
        <hc:Card Grid.Row="4" Margin="0,0,0,15" Padding="10">
            <ListBox x:Name="LogListBox" ItemsSource="{Binding Logs}" BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </hc:Card>

        <!-- 底部说明 -->
        <TextBlock Grid.Row="5" Text="提示：选择源目录、目标目录和年份，点击扫描查找该年份修改的文件，确认后点击开始迁移将文件移动至目标目录的年份子目录中。"
                   Opacity="0.6" Margin="0,10,0,0" TextWrapping="Wrap"/>
    </Grid>
</hc:Window>
