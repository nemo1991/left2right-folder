<Window x:Class="file_sync.S3DownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="从对象存储下载" Height="750" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        Icon="icon.ico">

    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 返回主页 -->
        <Button x:Name="BackButton" Grid.Row="0" Content="← 返回主页"
                Background="Transparent" Foreground="#0078D4" BorderThickness="0"
                Padding="0" Margin="0,0,0,15" HorizontalAlignment="Left"
                Cursor="Hand" FontSize="13" Click="BackButton_Click"/>

        <!-- 存储配置 -->
        <GroupBox Grid.Row="1" Header="存储配置" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 存储类型 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="存储类型:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <ComboBox x:Name="StorageTypeComboBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"
                          HorizontalAlignment="Left" Width="180" SelectionChanged="StorageTypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="AWS S3"/>
                    <ComboBoxItem Content="阿里云 OSS"/>
                    <ComboBoxItem Content="腾讯云 COS"/>
                    <ComboBoxItem Content="MinIO"/>
                </ComboBox>
                <TextBlock x:Name="EndpointHint" Grid.Row="0" Grid.Column="2" Text="s3.amazonaws.com"
                           VerticalAlignment="Center" Margin="15,0,0,10" Foreground="#999" FontSize="12"/>

                <!-- Endpoint -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Endpoint:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10"
                         Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- AccessKey -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="AccessKey:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <PasswordBox x:Name="AccessKeyBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10"
                             PasswordChanged="AccessKeyBox_PasswordChanged"/>

                <!-- SecretKey -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="SecretKey:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <PasswordBox x:Name="SecretKeyBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                             PasswordChanged="SecretKeyBox_PasswordChanged"/>
            </Grid>
        </GroupBox>

        <!-- Bucket 配置 -->
        <GroupBox Grid.Row="2" Header="Bucket 配置" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Bucket -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Bucket:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding Bucket, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- 存储路径前缀 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="存储路径:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding DownloadPrefix, UpdateSourceTrigger=PropertyChanged}"
                             Tag="(可选，填写路径前缀如 folder/）"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- 下载配置 -->
        <GroupBox Grid.Row="3" Header="下载配置" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 本地目录 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="本地目录:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding LocalDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button x:Name="BrowseButton" Grid.Column="2" Content="浏览..." Width="80" Margin="10,0,0,0"
                            Click="BrowseButton_Click"/>
                </Grid>

                <!-- 通配符 -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="通配符:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding WildcardPattern, UpdateSourceTrigger=PropertyChanged}"
                             Tag="(如 *.jpg, *.png, folder/*.zip)"/>
                </Grid>

                <!-- 扫描选项 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox IsChecked="{Binding UseTrieScan}" VerticalAlignment="Center">
                        <TextBlock Text="使用前缀树扫描（推荐）" VerticalAlignment="Center"/>
                    </CheckBox>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ListButton" Content="列出文件" Width="100" Margin="0,0,10,0"
                            IsEnabled="{Binding CanList, Mode=OneWay}" Click="ListButton_Click"/>
                    <Button x:Name="DownloadButton" Content="下载" Width="100" Margin="0,0,10,0"
                            IsEnabled="{Binding CanDownload, Mode=OneWay}" Click="DownloadButton_Click"/>
                    <Button x:Name="CancelButton" Content="取消" Width="80" IsCancel="True"
                            IsEnabled="{Binding CanCancel, Mode=OneWay}" Click="CancelButton_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 进度条 -->
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                         IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                         Height="20" Minimum="0" Maximum="100"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 日志区域 -->
        <GroupBox Grid.Row="5" Header="操作日志" Padding="10">
            <ListBox ItemsSource="{Binding Logs}" BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
    </Grid>
    </ScrollViewer>
</Window>
