<hc:Window x:Class="file_sync.S3DownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="从对象存储下载" Height="550" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource RegionBrush}"
        Icon="icon.ico">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 存储配置 -->
        <hc:Card Grid.Row="0" Margin="0,0,0,10" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 第一行: 存储类型 + Bucket + Endpoint -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="存储类型:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="StorageTypeComboBox" SelectedIndex="0"
                          Width="140" Margin="0,0,8,0"
                          SelectionChanged="StorageTypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="AWS S3"/>
                    <ComboBoxItem Content="阿里云 OSS"/>
                    <ComboBoxItem Content="腾讯云 COS"/>
                    <ComboBoxItem Content="MinIO"/>
                </ComboBox>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Bucket:" VerticalAlignment="Center"/>
                <hc:TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Bucket, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Endpoint:" VerticalAlignment="Center"/>
                <hc:TextBox Grid.Row="0" Grid.Column="5" Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- 第二行: AccessKey + SecretKey -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="AccessKey:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="AccessKeyBox" Margin="0,8,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="SecretKey:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <PasswordBox Grid.Row="1" Grid.Column="3" x:Name="SecretKeyBox" Margin="0,8,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="4" Text="提示:" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="5" x:Name="EndpointHint" Text="s3.amazonaws.com"
                           VerticalAlignment="Center" Margin="0,8,0,0" Opacity="0.6"/>
            </Grid>
        </hc:Card>

        <!-- 下载配置 -->
        <hc:Card Grid.Row="1" Margin="0,0,0,10" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 本地目录 + 路径前缀 + 浏览按钮 -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="本地目录:" VerticalAlignment="Center"/>
                    <hc:TextBox Grid.Column="1" Text="{Binding LocalDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Column="2" Text="路径前缀:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <hc:TextBox Grid.Column="3" Text="{Binding DownloadPrefix, UpdateSourceTrigger=PropertyChanged}"
                               hc:InfoElement.Placeholder="如 folder/" Margin="8,0,0,0"/>
                    <Button Grid.Column="4" x:Name="BrowseButton" Content="浏览..." Width="70" Margin="8,0,0,0"/>
                </Grid>

                <!-- 通配符 + 选项 + 按钮 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="通配符:" VerticalAlignment="Center"/>
                    <hc:TextBox Grid.Column="1" Text="{Binding WildcardPattern, UpdateSourceTrigger=PropertyChanged}"
                               hc:InfoElement.Placeholder="如 *.jpg, *.png"/>
                    <CheckBox Grid.Column="2" IsChecked="{Binding UseTrieScan}" Content="前缀树扫描"
                              Margin="15,0,0,0" VerticalAlignment="Center"/>
                    <Button Grid.Column="3" x:Name="ListButton" Content="列出文件" Width="80" Margin="15,0,0,0"/>
                    <Button Grid.Column="4" x:Name="DownloadButton" Content="下载" Width="70" Margin="8,0,0,0"/>
                </Grid>
            </Grid>
        </hc:Card>

        <!-- 进度条 + 取消按钮 -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                             Maximum="100" Minimum="0"
                             IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                             Height="20" Margin="0,0,0,0"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
            <Button Grid.Column="2" x:Name="CancelButton" Content="取消"
                    Style="{StaticResource ButtonDanger}" Width="60"/>
        </Grid>

        <!-- 日志区域 -->
        <hc:Card Grid.Row="3" Padding="8">
            <ListBox ItemsSource="{Binding Logs}" BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"
                                   FontSize="12"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </hc:Card>
    </Grid>
</hc:Window>
