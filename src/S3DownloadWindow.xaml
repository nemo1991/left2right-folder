<hc:Window x:Class="file_sync.S3DownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:file_sync"
        mc:Ignorable="d"
        Title="从对象存储下载" Height="750" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource RegionBrush}"
        Icon="icon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 返回主页 -->
        <Button x:Name="BackButton" Grid.Row="0" Content="返回主页"
                Style="{StaticResource ButtonDefault}" HorizontalAlignment="Left"
                Margin="0,0,0,15" Click="BackButton_Click"/>

        <!-- 存储配置 -->
        <hc:Card Grid.Row="1" Margin="0,0,0,15" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 存储类型 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="存储类型:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <ComboBox x:Name="StorageTypeComboBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"
                          HorizontalAlignment="Left" Width="180"
                          SelectionChanged="StorageTypeComboBox_SelectionChanged">
                    <ComboBoxItem Content="AWS S3"/>
                    <ComboBoxItem Content="阿里云 OSS"/>
                    <ComboBoxItem Content="腾讯云 COS"/>
                    <ComboBoxItem Content="MinIO"/>
                </ComboBox>
                <TextBlock x:Name="EndpointHint" Grid.Row="0" Grid.Column="2" Text="s3.amazonaws.com"
                           VerticalAlignment="Center" Margin="15,0,0,10" Opacity="0.6"/>

                <!-- Endpoint -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Endpoint:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <hc:TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10"
                           Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- AccessKey -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="AccessKey:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <PasswordBox x:Name="AccessKeyBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10"/>

                <!-- SecretKey -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="SecretKey:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <PasswordBox x:Name="SecretKeyBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"/>
            </Grid>
        </hc:Card>

        <!-- Bucket 配置 -->
        <hc:Card Grid.Row="2" Margin="0,0,0,15" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Bucket -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Bucket:" VerticalAlignment="Center"/>
                    <hc:TextBox Grid.Column="1" Text="{Binding Bucket, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- 存储路径前缀 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="存储路径:" VerticalAlignment="Center"/>
                    <hc:TextBox Grid.Column="1" Text="{Binding DownloadPrefix, UpdateSourceTrigger=PropertyChanged}"
                               hc:InfoElement.Placeholder="可选，填写路径前缀如 folder/"/>
                </Grid>
            </Grid>
        </hc:Card>

        <!-- 下载配置 -->
        <hc:Card Grid.Row="3" Margin="0,0,0,15" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 本地目录 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="本地目录:" VerticalAlignment="Center"/>
                    <hc:TextBox Grid.Column="1" Text="{Binding LocalDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button x:Name="BrowseButton" Grid.Column="2" Content="浏览..." Width="80" Margin="10,0,0,0"/>
                </Grid>

                <!-- 通配符 -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="通配符:" VerticalAlignment="Center"/>
                    <hc:TextBox Grid.Column="1" Text="{Binding WildcardPattern, UpdateSourceTrigger=PropertyChanged}"
                               hc:InfoElement.Placeholder="如 *.jpg, *.png, folder/*.zip"/>
                </Grid>

                <!-- 扫描选项 -->
                <CheckBox Grid.Row="2" IsChecked="{Binding UseTrieScan}" Content="使用前缀树扫描（推荐）" Margin="0,0,0,10"/>

                <!-- 操作按钮 -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ListButton" Content="列出文件" Width="100" Margin="0,0,10,0"/>
                    <Button x:Name="DownloadButton" Content="下载" Width="100" Margin="0,0,10,0"/>
                    <Button x:Name="CancelButton" Content="取消" Width="80"/>
                </StackPanel>
            </Grid>
        </hc:Card>

        <!-- 进度条 -->
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <hc:CircleProgressBar Grid.Column="0" Value="{Binding ProgressValue, Mode=OneWay}"
                                IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"
                                ShowText="False" Height="24"/>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- 日志区域 -->
        <hc:Card Grid.Row="5" Padding="10">
            <ListBox ItemsSource="{Binding Logs}" BorderThickness="0"
                     Background="Transparent" MaxHeight="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                   Foreground="{Binding IsError, Converter={StaticResource BoolToColorConverter}, FallbackValue=Black}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </hc:Card>
    </Grid>
</hc:Window>
